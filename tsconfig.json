{
    "compilerOptions": {
        "target": "ES2023",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": false,
        "outDir": "dist",
        "rootDir": ".",
        "skipLibCheck": true
    },
    "include": [
        "scripts/**/*.mts"
    ],
    "exclude": [
        "node_modules",
        "docs",
        "dist"
    ]
}
